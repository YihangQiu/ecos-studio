FROM ubuntu:24.04

SHELL ["/bin/bash", "-lc"]

RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
    git \
    make \
    curl \
    wget \
    bzip2 \
    ca-certificates \
    findutils \
    xz-utils \
    nix-bin \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /etc/nix \
    && printf "experimental-features = nix-command flakes\naccept-flake-config = true\n" > /etc/nix/nix.conf

WORKDIR /workspace

CMD ["bash"]
